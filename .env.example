# =============================================================================
# Portfolio — environment variables (copy to .env.local, never commit secrets)
# =============================================================================

# --- Database (Prisma / PostgreSQL) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

# --- NestJS project API (optional; public timeline reads from here when set) ---
API_URL=http://localhost:3001

# --- Supabase ---
# URL hostname is also used for Next.js Image remotePatterns (no hardcoded project id).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-anon-key
# Server only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- OpenAI (RAG chat + project indexing) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Admin CMS ---
# Obscured path segment (still exposed in client bundle via NEXT_PUBLIC_ prefix).
NEXT_PUBLIC_ADMIN_SECRET_PATH=your-secret-admin-path
# Optional: custom slug for "new project" route rewrite (default: new)
# NEXT_PUBLIC_ADMIN_PROJECT_NEW_SLUG=new
# Set to "true" only when you intentionally allow admin sign-up (default: disabled)
NEXT_PUBLIC_ADMIN_SIGNUP_ENABLED=false

# --- Sentry ---
# Use the same DSN for server + client, or set both SENTRY_DSN and NEXT_PUBLIC_SENTRY_DSN.
SENTRY_DSN=https://YOUR_KEY@oORG_ID.ingest.us.sentry.io/PROJECT_ID
NEXT_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oORG_ID.ingest.us.sentry.io/PROJECT_ID
# Build-time source map upload (Vercel / CI)
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
# SENTRY_AUTH_TOKEN=sntrys_your_token

# --- Analytics (optional) ---
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
# GA4_PROPERTY_ID=
# GA4_SERVICE_ACCOUNT_JSON=

# --- Kakao (optional) ---
NEXT_PUBLIC_KAKAO_APP_KEY=
