// Prisma schema — JSONB i18n projects + story detail pages (matches Nest backend DB shape)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id                 Int       @id @default(autoincrement())
  sortOrder          Int       @default(0) @map("sort_order")
  imageUrl           String    @map("image_url")
  startDate          DateTime  @map("start_date")
  endDate            DateTime? @map("end_date")
  isPublic           Boolean   @default(false) @map("is_public")

  technologies       String[]  @default([])
  platformCategories String[] @default([]) @map("platform_categories")
  domainTags         String[]  @default([]) @map("domain_tags")

  title        Json @db.JsonB
  company      Json @db.JsonB
  region       Json @db.JsonB
  role         Json @db.JsonB
  overview     Json @db.JsonB
  description  Json @db.JsonB
  challenges   Json @db.JsonB
  achievements Json @db.JsonB
  platforms    Json @db.JsonB
  tools        Json @db.JsonB

  detailPage ProjectDetailPage?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("projects")
}

model ProjectDetailPage {
  id        Int     @id @default(autoincrement())
  projectId Int     @unique @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  content  Json    @default("{}") @db.JsonB
  isPublic Boolean @default(false) @map("is_public")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("project_detail_pages")
}

model PortfolioDocument {
  id         BigInt                 @id @default(autoincrement())
  sourceType String                 @map("source_type")
  sourceId   Int                    @map("source_id")
  locale     String
  title      String
  content    String                 @db.Text
  metadata   Json                   @default("{}") @db.JsonB
  embedding  Unsupported("vector(1536)")
  createdAt  DateTime               @default(now()) @map("created_at")
  updatedAt  DateTime               @default(now()) @updatedAt @map("updated_at")

  @@unique([sourceType, sourceId, locale], map: "portfolio_documents_source_unique")
  @@index([sourceType, sourceId, locale], map: "portfolio_documents_source_idx")
  @@map("portfolio_documents")
}
